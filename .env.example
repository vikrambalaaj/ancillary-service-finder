# Copy this file to `.env` and adjust as needed. The app loads `.env` automatically.

# Farelogix ServiceList endpoint hit by the Search button.
FARELOGIX_URL=https://ekd.farelogix.com/sandbox-uat/flxm

# Request timeout in milliseconds.
FARELOGIX_TIMEOUT_MS=20000

# Set to "true" to skip the live call and return the attached sample response
# (useful when offline). Default: live call.
USE_SAMPLE_RESPONSE=false

# Always show services: when the live endpoint returns none (fault/empty),
# fall back to representative sample services so the Services tab is never empty.
# Set to "false" to show the real "No services found" state instead. Default: true.
ALWAYS_SHOW_SERVICES=true

# Server port.
PORT=3000
